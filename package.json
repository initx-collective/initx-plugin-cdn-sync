{
  "name": "initx-plugin-cdn-sync",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.1",
  "description": "CDN file sync plugin for initx - Upload files to Tencent Cloud COS",
  "author": "imba97",
  "license": "MIT",
  "homepage": "https://github.com/initx-collective/initx-plugin-cdn-sync#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:initx-collective/initx-plugin-cdn-sync.git"
  },
  "bugs": {
    "url": "https://github.com/initx-collective/initx-plugin-cdn-sync/issues"
  },
  "keywords": [
    "initx",
    "initx-plugin"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "stub": "unbuild --stub",
    "build": "unbuild",
    "release": "bumpp",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@initx-plugin/core": "*",
    "@initx-plugin/utils": "*"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "defu": "^6.1.7",
    "p-limit": "^7.3.0",
    "picospinner": "^3.0.0",
    "simple-git": "^3.36.0",
    "tinyglobby": "^0.2.16",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@initx-plugin/core": "^0.3.6",
    "@initx-plugin/utils": "^0.3.6",
    "@types/node": "^25.7.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.3.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
